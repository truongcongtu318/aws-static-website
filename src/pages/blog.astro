---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const posts = [
  {
    title: "Building a Production-Ready Static Website on AWS",
    excerpt: "The journey of deploying a personal portfolio with S3, CloudFront, Route 53, and a full CI/CD pipeline using OIDC — no passwords stored.",
    date: "Apr 13, 2024",
    readTime: "8 min read",
    tags: ["AWS", "CI/CD", "CloudFront", "GitHub Actions"],
    featured: true
  },
  {
    title: "OIDC: Connect GitHub to AWS Without Access Keys",
    excerpt: "Step-by-step guide to configuring OpenID Connect so GitHub Actions can deploy to AWS securely — zero long-lived credentials.",
    date: "Apr 10, 2024",
    readTime: "5 min read",
    tags: ["Security", "OIDC", "IAM"],
    featured: false
  },
  {
    title: "Astro vs Next.js: Which One for a Static Portfolio?",
    excerpt: "A detailed comparison of the two most popular frameworks for static websites — performance, cost, developer experience.",
    date: "Apr 5, 2024",
    readTime: "6 min read",
    tags: ["Astro", "Next.js", "Performance"],
    featured: false
  },
  {
    title: "Securing S3 with CloudFront Origin Access Control",
    excerpt: "How to configure CloudFront to access a private S3 bucket — replacing the legacy OAI with the modern OAC mechanism.",
    date: "Apr 1, 2024",
    readTime: "4 min read",
    tags: ["CloudFront", "S3", "Security"],
    featured: false
  }
];

const featured = posts.find(p => p.featured);
const rest = posts.filter(p => !p.featured);
---

<Layout title="Blog | Truong Tu Dev">
  <Navbar active="blog" />

  <main class="page">
    <div class="page-header">
      <h1>The <span class="muted">Blog</span></h1>
      <p>Sharing knowledge about Cloud, DevOps, and my AWS learning journey</p>
    </div>

    {featured && (
      <article class="featured-post">
        <div class="featured-visual"></div>
        <div class="featured-content">
          <div class="post-meta">
            <span class="date">{featured.date}</span>
            <span class="dot-sep">·</span>
            <span class="read-time">{featured.readTime}</span>
            <span class="badge">✦ Featured</span>
          </div>
          <h2>{featured.title}</h2>
          <p>{featured.excerpt}</p>
          <div class="tags">
            {featured.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <a href="#" class="read-more">Read article ↗</a>
        </div>
      </article>
    )}

    <div class="posts-grid">
      {rest.map(post => (
        <article class="post-card">
          <div class="post-visual"></div>
          <div class="post-content">
            <div class="post-meta">
              <span class="date">{post.date}</span>
              <span class="dot-sep">·</span>
              <span class="read-time">{post.readTime}</span>
            </div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <div class="tags">
              {post.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <a href="#" class="read-more">Read article ↗</a>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style>
  .page { padding: 40px 5% 120px; }

  .page-header { margin-bottom: 60px; }
  .page-header h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 16px;
  }
  .muted { color: var(--secondary); }
  .page-header p { font-size: 1rem; color: var(--secondary); }

  /* Featured */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #F0F0F0;
    border-radius: 28px;
    overflow: hidden;
    margin-bottom: 24px;
    transition: transform 0.3s;
  }
  .featured-post:hover { transform: translateY(-4px); }
  .featured-visual { min-height: 380px; background: #DCDCDC; }
  .featured-content {
    padding: 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Meta */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .date, .read-time { font-size: 0.8rem; font-weight: 600; color: var(--secondary); }
  .dot-sep { color: var(--secondary); font-size: 0.8rem; }
  .badge {
    background: var(--primary);
    color: white;
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 50px;
    font-weight: 700;
    margin-left: 4px;
  }

  .featured-content h2 {
    font-size: 1.7rem;
    letter-spacing: -1px;
    margin-bottom: 14px;
    line-height: 1.25;
  }
  .featured-content > p {
    color: var(--secondary);
    line-height: 1.65;
    margin-bottom: 24px;
    font-size: 0.92rem;
  }

  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px; }
  .tag {
    background: rgba(0,0,0,0.07);
    padding: 3px 10px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .read-more {
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--primary);
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
    align-self: flex-start;
  }

  /* Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .post-card {
    background: #F5F5F5;
    border-radius: 24px;
    overflow: hidden;
    transition: transform 0.3s;
  }
  .post-card:hover { transform: translateY(-4px); }
  .post-visual { height: 180px; background: #E0E0E0; }
  .post-content { padding: 28px; }
  .post-content h3 {
    font-size: 1.1rem;
    letter-spacing: -0.5px;
    margin: 12px 0 10px;
    line-height: 1.3;
  }
  .post-content > p {
    color: var(--secondary);
    font-size: 0.87rem;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  @media (max-width: 900px) {
    .featured-post { grid-template-columns: 1fr; }
    .posts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
