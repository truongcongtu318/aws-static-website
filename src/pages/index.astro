---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ServiceCard from '../components/ServiceCard.astro';

const techStack = [
  { label: "Cloud", items: ["AWS S3", "CloudFront", "ECS", "Lambda", "RDS"] },
  { label: "DevOps", items: ["GitHub Actions", "Docker", "Kubernetes", "Terraform"] },
  { label: "Web", items: ["Astro", "React", "Node.js", "TypeScript"] },
];
---

<Layout title="Truong Tu | Cloud Engineer & Developer">
  <Navbar active="about" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-left">
      <div class="label-row">
        <span class="chip">Open for Intern/Junior roles</span>
        <span class="chip">Tech Enthusiast 🚀</span>
      </div>

      <h1 class="headline">
        DevOps<br />
        <span class="outline">Engineer</span><br />
        &amp; Developer
      </h1>

      <p class="lead">
        Exploring the world of Cloud Infrastructure & Automation. 
        I'm passionate about building clean CI/CD pipelines and learning how to scale applications effectively on AWS.
      </p>

      <div class="hero-actions">
        <a href="/portfolio" class="btn-primary">Explore My Labs ↗</a>
        <a href="mailto:tct31082004@gmail.com" class="btn-ghost">Let's talk</a>
      </div>
    </div>

    <div class="hero-right">
      <!-- Stats thực tế hơn cho Intern -->
      <div class="stats-block">
        <div class="stat">
          <strong>10+</strong>
          <span>Hands-on Labs</span>
        </div>
        <div class="stat">
          <strong>24/7</strong>
          <span>Learning Path</span>
        </div>
        <div class="stat">
          <strong>100%</strong>
          <span>Dedicated</span>
        </div>
      </div>

      <!-- Tech stack -->
      <div class="stack-block">
        {techStack.map(group => (
          <div class="stack-group">
            <span class="stack-label">{group.label}</span>
            <div class="stack-items">
              {group.items.map(item => <span class="stack-pill">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider">
    <span>Selected services</span>
    <div class="line"></div>
  </div>

  <!-- Services -->
  <section class="services" id="services">
    <div class="services-grid">
      <ServiceCard icon="☁️" title="AWS Cloud Architecture" desc="Deploy serverless infrastructure with S3, CloudFront, ECS and Lambda on AWS." />
      <ServiceCard icon="🤖" title="DevOps & CI/CD" desc="Build automated deployment pipelines with GitHub Actions, Docker and Kubernetes." />
      <ServiceCard icon="🌐" title="Web Development" desc="Build high-performance websites and apps using Astro, React and modern tech." />
    </div>

    <div class="services-footer">
      <p>Interested in working together?</p>
      <a href="mailto:tct31082004@gmail.com" class="contact-link">tct31082004@gmail.com ↗</a>
    </div>
  </section>
</Layout>

<style>
  /* ─── Hero ───────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 80px 5% 120px;
    align-items: center;
    min-height: calc(100vh - 100px);
  }

  /* Left */
  .hero-left { display: flex; flex-direction: column; gap: 32px; }

  .label-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .chip {
    background: var(--tertiary);
    border: 1px solid #E0E0E0;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--secondary);
  }

  .headline {
    font-size: clamp(3.2rem, 6vw, 6rem);
    font-weight: 700;
    letter-spacing: -3px;
    line-height: 1;
  }
  .outline {
    -webkit-text-stroke: 2px var(--primary);
    color: transparent;
  }

  .lead {
    font-size: 1.05rem;
    color: var(--secondary);
    line-height: 1.7;
    max-width: 420px;
  }

  .hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

  .btn-primary {
    text-decoration: none;
    background: var(--primary);
    color: white;
    padding: 14px 28px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.8; }

  .btn-ghost {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
  }

  /* Right */
  .hero-right { display: flex; flex-direction: column; gap: 40px; }

  /* Stats */
  .stats-block {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    background: var(--tertiary);
    border-radius: 24px;
    padding: 32px 28px;
  }
  .stat { text-align: center; }
  .stat strong {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat span {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Tech stack */
  .stack-block {
    background: var(--primary);
    border-radius: 24px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .stack-group {}
  .stack-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 10px;
  }
  .stack-items { display: flex; flex-wrap: wrap; gap: 8px; }
  .stack-pill {
    background: rgba(255,255,255,0.12);
    color: white;
    padding: 5px 12px;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 500;
  }

  /* ─── Divider ─────────────────────────────── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 5%;
    margin-bottom: 48px;
  }
  .section-divider span {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--secondary);
    white-space: nowrap;
  }
  .line { flex: 1; height: 1px; background: #E0E0E0; }

  /* ─── Services ───────────────────────────── */
  .services { padding: 0 5% 120px; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  .services-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 40px;
    background: var(--tertiary);
    border-radius: 24px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .services-footer p {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .contact-link {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
  }

  /* ─── Responsive ─────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 60px 5% 80px;
      min-height: auto;
      gap: 60px;
    }
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
