---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Truong Tu | DevOps & Cloud Engineer">
  <Navbar active="about" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-left">
      <div class="label-row">
        <span class="chip">Open for Opportunities</span>
        <span class="chip">Da Nang, Vietnam 🇻🇳</span>
      </div>

      <h1 class="headline">
        DevOps<br />
        <span class="outline">Engineer</span><br />
        &amp; Developer
      </h1>

      <p class="lead">
        Final-year Software Engineering student at <strong>Vietnam-Korea University of ICT</strong>. 
        Passionate about Cloud Infrastructure, CI/CD Automation, and building scalable systems on AWS.
      </p>

      <div class="hero-actions">
        <a href="/portfolio" class="btn-primary">View My Projects ↗</a>
        <a href="mailto:tct31082004@gmail.com" class="btn-ghost">Email Me</a>
      </div>

      <div class="social-links">
        <a href="https://github.com/truongcongtu318" target="_blank">GitHub</a>
        <span class="sep">/</span>
        <a href="https://linkedin.com/in/truong-cong-tu" target="_blank">LinkedIn</a>
        <span class="sep">/</span>
        <a href="tel:0352029544">0352 029 544</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="bento-grid">
        <!-- Card 1: Current Job (Xbrain) -->
        <div class="bento-item current-job">
          <div class="card-head">
            <span class="badge">Current</span>
            <span class="comp">Xbrain</span>
          </div>
          <h3>DevOps Engineer Intern</h3>
          <p>Designing AWS infrastructure and automating CI/CD pipelines.</p>
          <div class="card-footer">
            <span class="date">April 2026 — Present</span>
          </div>
        </div>

        <!-- Card 2: Technical Stack -->
        <div class="bento-item stack-card">
          <span class="stack-label">Core Tech</span>
          <div class="stack-items">
            <span class="stack-pill">AWS</span>
            <span class="stack-pill">Docker</span>
            <span class="stack-pill">Terraform</span>
          </div>
        </div>

        <!-- Card 3: Previous Role -->
        <div class="bento-item past-job">
          <span class="badge gray">Previous Case</span>
          <h4>Software Engineer</h4>
          <span class="comp-small">Thien An Studio</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider: About Me -->
  <div class="section-divider">
    <span>About Me</span>
    <div class="line"></div>
  </div>

  <section class="about">
    <div class="about-grid">
      <div class="about-text">
        <h2>From <span class="muted">Mobile Dev</span> to <span class="muted">Cloud Engineer</span></h2>
        <p>
          I started my career as a Flutter developer, building mobile applications during a 6-month internship. 
          That experience taught me the importance of deployment pipelines and infrastructure — 
          which led me to discover my true passion: <strong>DevOps & Cloud Engineering</strong>.
        </p>
        <p>
          Now I'm focused on designing automated CI/CD workflows, containerized deployments, 
          and scalable AWS architectures. I believe in learning by building — every project in my portfolio 
          is a real, deployed system, not just code on GitHub.
        </p>
      </div>
      <div class="about-highlights">
        <div class="highlight">
          <span class="highlight-icon">🎓</span>
          <div>
            <strong>Education</strong>
            <p>B.Sc. Software Engineering — Vietnam-Korea University of ICT (VKU), Da Nang</p>
          </div>
        </div>
        <div class="highlight">
          <span class="highlight-icon">🎯</span>
          <div>
            <strong>Goal</strong>
            <p>Become a professional DevOps Engineer, specializing in AWS and Infrastructure as Code</p>
          </div>
        </div>
        <div class="highlight">
          <span class="highlight-icon">📜</span>
          <div>
            <strong>Certifications</strong>
            <p>Currently studying for AWS Cloud Practitioner</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider: Experience -->
  <div class="section-divider">
    <span>Work Experience</span>
    <div class="line"></div>
  </div>

  <section class="experience">
    <div class="exp-list">
      <div class="exp-item">
        <div class="exp-meta">
          <span class="exp-date">April 2026 — Present</span>
          <span class="exp-type current">Current</span>
        </div>
        <div class="exp-content">
          <div class="exp-header">
            <h3>DevOps & Cloud Engineer Intern</h3>
            <span class="exp-company">Xbrain</span>
          </div>
          <p>
            Design and manage AWS cloud infrastructure. Build CI/CD pipelines with GitHub Actions using OIDC authentication.
            Deploy containerized applications with Docker and ECS Fargate. Implement monitoring and security best practices.
          </p>
          <div class="exp-tags">
            <span>AWS</span><span>Docker</span><span>GitHub Actions</span><span>CloudFront</span><span>ECS</span>
          </div>
        </div>
      </div>

      <div class="exp-item">
        <div class="exp-meta">
          <span class="exp-date">2025 — 2026</span>
          <span class="exp-type">6 months</span>
        </div>
        <div class="exp-content">
          <div class="exp-header">
            <h3>Software Engineer Intern</h3>
            <span class="exp-company">Thien An Studio</span>
          </div>
          <p>
            Developed cross-platform mobile applications using Flutter and Dart.
            Collaborated with the design team to implement pixel-perfect UI components and integrated RESTful APIs for backend communication.
          </p>
          <div class="exp-tags">
            <span>Flutter</span><span>Dart</span><span>REST API</span><span>Firebase</span><span>Git</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="footer-cta">
    <div class="cta-inner">
      <h2>Let's work together</h2>
      <p>I'm open to internship and junior DevOps/Cloud positions. Feel free to reach out!</p>
      <div class="cta-links">
        <a href="mailto:tct31082004@gmail.com" class="cta-link">tct31082004@gmail.com ↗</a>
        <span class="cta-sep">|</span>
        <a href="tel:0352029544" class="cta-link">0352 029 544 ↗</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ─── Variables ──────────────────────────── */
  :root {
    --primary: #1A1A1A;
    --secondary: #888888;
    --tertiary: #F5F5F5;
  }

  /* ─── Hero ───────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 60px 5% 100px;
    align-items: center;
    min-height: calc(100vh - 100px);
  }

  .hero-left { display: flex; flex-direction: column; gap: 28px; }

  .label-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .chip {
    background: var(--tertiary);
    border: 1px solid #E0E0E0;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--secondary);
  }

  .headline {
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -3px;
    line-height: 1;
  }
  .outline {
    -webkit-text-stroke: 2px var(--primary);
    color: transparent;
  }

  .lead {
    font-size: 1rem;
    color: var(--secondary);
    line-height: 1.7;
    max-width: 440px;
  }
  .lead strong { color: var(--primary); }

  .hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

  .btn-primary {
    text-decoration: none;
    background: var(--primary);
    color: white;
    padding: 14px 28px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.8; }

  .btn-ghost {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
  }

  /* Social Links under buttons */
  .social-links {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }
  .social-links a {
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--secondary);
    transition: color 0.2s;
  }
  .social-links a:hover { color: var(--primary); }
  .sep {
    color: #E0E0E0;
    font-size: 0.8rem;
  }

  /* Right column - Bento Grid */
  .hero-right { display: flex; flex-direction: column; width: 100%; }

  .bento-item {
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: transform 0.3s ease;
  }
  .bento-item:hover { transform: translateY(-5px); }
  /* Current Job Card */
  .current-job {
    grid-column: span 2;
    background: var(--primary);
    color: white;
    padding: 32px;
  }
  .card-head { display: flex; justify-content: space-between; margin-bottom: 20px; align-items: center; }
  .badge {
    background: #4A90E2;
    color: white;
    font-size: 0.65rem;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 50px;
    text-transform: uppercase;
  }
  .badge.gray { background: rgba(0,0,0,0.1); color: var(--secondary); }
  .comp { font-weight: 700; font-size: 1.1rem; }
  .current-job h3 { font-size: 1.6rem; margin: 0 0 12px; line-height: 1.2; }
  .current-job p { opacity: 0.6; font-size: 0.9rem; margin-bottom: 20px; }
  .card-footer .date { font-size: 0.75rem; font-weight: 600; opacity: 0.4; }

  /* Stack Card */
  .stack-card {
    background: #E3F2FD;
    padding: 24px;
  }
  
  /* Past Job Card */
  .past-job {
    background: #F5F5F5;
    padding: 24px;
  }
  .past-job h4 { font-size: 1rem; margin: 8px 0 4px; }
  .comp-small { font-size: 0.8rem; color: var(--secondary); font-weight: 600; }

  .stack-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.5;
  }
  .stack-items { display: flex; flex-wrap: wrap; gap: 6px; }
  .stack-pill {
    padding: 4px 10px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.2);
  }
  .stack-card .stack-pill { background: rgba(0,0,0,0.05); }

  /* ─── Section Divider ───────────────────── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 5%;
    margin-bottom: 48px;
  }
  .section-divider span {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--secondary);
    white-space: nowrap;
  }
  .line { flex: 1; height: 1px; background: #E0E0E0; }

  /* ─── About ─────────────────────────────── */
  .about { padding: 0 5% 80px; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .about-text h2 {
    font-size: 1.8rem;
    letter-spacing: -1px;
    margin-bottom: 24px;
    line-height: 1.2;
  }
  .muted { color: var(--secondary); }

  .about-text p {
    color: var(--secondary);
    line-height: 1.7;
    margin-bottom: 16px;
    font-size: 0.95rem;
  }
  .about-text strong { color: var(--primary); }

  .about-highlights {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .highlight {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--tertiary);
    padding: 24px;
    border-radius: 20px;
  }
  .highlight-icon { font-size: 1.6rem; }
  .highlight strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 6px;
  }
  .highlight p {
    font-size: 0.85rem;
    color: var(--secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── Experience ────────────────────────── */
  .experience { padding: 0 5% 80px; }
  .exp-list { display: flex; flex-direction: column; gap: 0; }

  .exp-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 40px;
    padding: 36px 0;
    border-bottom: 1px solid #EEEEEE;
  }
  .exp-item:first-child { padding-top: 0; }
  .exp-item:last-child { border-bottom: none; }

  .exp-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .exp-date {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--secondary);
  }
  .exp-type {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--secondary);
    background: var(--tertiary);
    padding: 3px 10px;
    border-radius: 50px;
    width: fit-content;
  }
  .exp-type.current {
    background: #E8F5E9;
    color: #2E7D32;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .exp-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }
  .exp-company {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--secondary);
  }
  .exp-content p {
    font-size: 0.9rem;
    color: var(--secondary);
    line-height: 1.65;
    margin-bottom: 16px;
  }
  .exp-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .exp-tags span {
    background: var(--tertiary);
    padding: 4px 10px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  /* ─── Footer CTA ────────────────────────── */
  .footer-cta { padding: 0 5% 100px; }
  .cta-inner {
    background: var(--primary);
    color: white;
    padding: 64px;
    border-radius: 28px;
    text-align: center;
  }
  .cta-inner h2 {
    font-size: 2rem;
    margin-bottom: 12px;
    letter-spacing: -1px;
  }
  .cta-inner p {
    opacity: 0.6;
    margin-bottom: 28px;
    font-size: 0.95rem;
  }
  .cta-link {
    text-decoration: none;
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 1.5px solid white;
    padding-bottom: 2px;
  }
  .cta-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .cta-sep {
    opacity: 0.3;
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 40px 5% 60px;
      min-height: auto;
      gap: 48px;
    }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .exp-item { grid-template-columns: 1fr; gap: 12px; }
    .cta-inner { padding: 40px 24px; }
  }
</style>
