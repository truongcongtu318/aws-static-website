---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Truong Tu | Cloud Engineer & Developer">
  <Navbar active="about" />

  <!-- Hero -->
  <section class="hero">
    <span class="vertical-label">CLOUD ENGINEER</span>

    <div class="stats">
      <div class="stat">
        <strong>+200</strong>
        <span>PROJECTS DONE</span>
      </div>
      <div class="stat">
        <strong>+50</strong>
        <span>HAPPY CLIENTS</span>
      </div>
    </div>

    <div class="hero-text">
      <h1 class="headline">Hello</h1>
      <p class="subline">— It's Truong Tu, a Cloud Engineer</p>
    </div>

    <div class="scroll-hint">Scroll down ↓</div>

    <!-- Hero image: full height right side, transparent PNG -->
    <div class="hero-image-wrap">
      <img src="/me.png" alt="Truong Tu" class="hero-img" />
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="section-header">
      <h2>Services <span class="counter">03</span></h2>
      <a href="/services" class="view-all">View all ↗</a>
    </div>
    <div class="services-grid">
      <ServiceCard icon="☁️" title="AWS Cloud" desc="Deploy serverless infrastructure with S3, CloudFront, ECS and Lambda on AWS." />
      <ServiceCard icon="🤖" title="DevOps & CI/CD" desc="Build automated deployment pipelines with GitHub Actions, Docker and Kubernetes." />
      <ServiceCard icon="🌐" title="Web Development" desc="Build high-performance websites using Astro, React and modern web technologies." />
    </div>
  </section>
</Layout>

<style>
  /* ─── Navbar ─────────────────────────────── */
  .navbar {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;

  /* ─── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 0 5% 80px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .vertical-label {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-rl;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--secondary);
  }

  .stats {
    display: flex;
    gap: 60px;
    position: absolute;
    top: 130px;
    left: 5%;
    z-index: 2;
  }
  .stat strong {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat span {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--secondary);
    text-transform: uppercase;
  }

  .hero-text { position: relative; z-index: 2; }

  .headline {
    font-size: clamp(5rem, 16vw, 14rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 0.85;
    margin-bottom: 16px;
  }
  .subline {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--primary);
  }

  .scroll-hint {
    margin-top: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    position: relative;
    z-index: 2;
    color: var(--secondary);
  }

  /* ─── Hero Image ─────────────────────────── */
  .hero-image-wrap {
    position: absolute;
    right: 0;
    top: 0;
    width: 52%;
    height: 100%;
    z-index: 1;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Loại bỏ nền trắng bằng multiply - chỉ giữ lại tông tối */
    mix-blend-mode: multiply;
  }

  /* ─── Services ───────────────────────────── */
  .services {
    padding: 120px 5%;
    position: relative;
    z-index: 3;
    background: var(--tertiary);
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
  }
  .section-header h2 {
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: -3px;
  }
  .counter { font-size: 1.2rem; color: var(--secondary); margin-left: 16px; }
  .view-all {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 4px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ─── Responsive ─────────────────────────── */
  @media (max-width: 768px) {
    .hero-image-wrap { width: 100%; right: 0; opacity: 0.12; }
    .stats { top: 110px; gap: 30px; }
    .services-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
</style>
