---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
---

<Layout title="TruongTu Dev | Cloud Engineer & Developer">
  <!-- Navbar -->
  <nav class="navbar">
    <div class="logo">D.NOVA <span class="dot">.</span></div>
    <ul class="nav-links">
      <li><a href="/" class="active">How we work</a></li>
      <li><a href="/portfolio">Portfolio</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/blog">Blog</a></li>
    </ul>
    <a href="#contact" class="btn-pill">Book A Call ↗</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <!-- Vertical label -->
    <span class="vertical-label">PRODUCT DESIGNER</span>

    <!-- Stats top left -->
    <div class="stats">
      <div class="stat">
        <strong>+200</strong>
        <span>PROJECT COMPLETED</span>
      </div>
      <div class="stat">
        <strong>+50</strong>
        <span>STARTUP RAISED</span>
      </div>
    </div>

    <!-- Big typography -->
    <div class="hero-text">
      <h1 class="headline">Hello</h1>
      <p class="subline">— It's Trương Tú, a Cloud Engineer</p>
    </div>

    <div class="scroll-hint">Scroll down ↓</div>

    <!-- Hero image: full-height, right side, overlapping text -->
    <div class="hero-image-wrap">
      <img src="/me.jpg" alt="Trương Tú" class="hero-img" onerror="this.style.background='linear-gradient(160deg,#ddd,#bbb)';this.style.display='block';this.removeAttribute('src')" />
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="section-header">
      <h2>Services <span class="counter">03</span></h2>
      <a href="/services" class="view-all">View all ↗</a>
    </div>
    <div class="services-grid">
      <ServiceCard icon="☁️" title="AWS Cloud" desc="Triển khai hạ tầng Serverless, bảo mật và hiệu năng cao trên AWS Cloud." />
      <ServiceCard icon="🤖" title="DevOps CI/CD" desc="Tự động hóa pipeline triển khai phần mềm chuẩn doanh nghiệp với GitHub Actions." />
      <ServiceCard icon="🎨" title="Web Development" desc="Xây dựng website hiệu năng cao bằng Astro, React và các công nghệ hiện đại." />
    </div>
  </section>
</Layout>

<style>
  /* ─── Navbar ─────────────────────────────── */
  .navbar {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32px 5%;
    z-index: 10;
  }
  .logo { font-weight: 800; font-size: 1.4rem; letter-spacing: -1px; }
  .logo .dot { color: var(--secondary); }
  .nav-links {
    display: flex;
    list-style: none;
    gap: 40px;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--secondary);
    font-weight: 600;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-links a.active, .nav-links a:hover { color: var(--primary); }

  /* ─── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 0 5%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 80px;
  }

  /* Vertical label */
  .vertical-label {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-rl;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--secondary);
  }

  /* Stats */
  .stats {
    display: flex;
    gap: 60px;
    position: absolute;
    top: 140px;
    left: 5%;
    z-index: 2;
  }
  .stat strong {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat span {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--secondary);
    text-transform: uppercase;
  }

  /* Big text */
  .hero-text {
    position: relative;
    z-index: 2;
  }
  .headline {
    font-size: clamp(5rem, 16vw, 14rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 0.85;
    margin-bottom: 16px;
  }
  .subline {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--primary);
  }

  .scroll-hint {
    margin-top: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    position: relative;
    z-index: 2;
  }

  /* Hero image: absolute right, full height */
  .hero-image-wrap {
    position: absolute;
    right: 0;
    top: 0;
    width: 50%;
    height: 100%;
    z-index: 1;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: 40px 0 0 40px;
    background: linear-gradient(160deg, #ddd, #bbb);
    display: block;
    min-height: 400px;
  }

  /* ─── Services ───────────────────────────── */
  .services {
    padding: 120px 5%;
    background: var(--tertiary);
    position: relative;
    z-index: 3;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
  }
  .section-header h2 {
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: -3px;
  }
  .counter { font-size: 1.2rem; color: var(--secondary); margin-left: 16px; }
  .view-all {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 4px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 768px) {
    .hero-image-wrap { width: 100%; border-radius: 0; opacity: 0.15; }
    .hero-image-wrap img { border-radius: 0; }
    .stats { top: 120px; }
    .services-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
</style>
