---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    id: 1,
    title: "AWS Static Website",
    tags: ["AWS S3", "CloudFront", "GitHub Actions", "Astro"],
    desc: "Website portfolio triển khai trên AWS với CI/CD Pipeline hoàn chỉnh sử dụng OIDC.",
    year: "2024",
    color: "#F0F0F0"
  },
  {
    id: 2,
    title: "3-Tier Architecture",
    tags: ["AWS ECS", "Docker", "RDS", "ALB"],
    desc: "Kiến trúc ứng dụng 3 lớp hoàn chỉnh trên AWS Cloud với khả năng scale tự động.",
    year: "2024",
    color: "#E8E8FF"
  },
  {
    id: 3,
    title: "Serverless API",
    tags: ["Lambda", "API Gateway", "DynamoDB"],
    desc: "RESTful API không máy chủ với khả năng xử lý hàng triệu request mỗi ngày.",
    year: "2024",
    color: "#F0F8F0"
  },
  {
    id: 4,
    title: "DevOps Dashboard",
    tags: ["Kubernetes", "Prometheus", "Grafana"],
    desc: "Hệ thống giám sát và quan sát toàn diện cho microservices trên Kubernetes.",
    year: "2024",
    color: "#FFF5E8"
  },
];
---

<Layout title="Portfolio | TruongTu Dev">
  <nav class="navbar">
    <div class="logo">D.NOVA <span class="dot">.</span></div>
    <ul class="nav-links">
      <li><a href="/">How we work</a></li>
      <li><a href="/portfolio" class="active">Portfolio</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/blog">Blog</a></li>
    </ul>
    <a href="/#contact" class="btn-pill">Book A Call ↗</a>
  </nav>

  <main class="portfolio-page">
    <div class="page-header">
      <h1>My <span class="muted">Work</span></h1>
      <p>Bộ sưu tập các dự án Cloud & DevOps của tôi</p>
    </div>

    <div class="projects-grid">
      {projects.map((p) => (
        <div class="project-card" style={`background: ${p.color}`}>
          <div class="project-visual"></div>
          <div class="project-info">
            <div class="project-meta">
              <span class="project-year">{p.year}</span>
              <div class="project-tags">
                {p.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <h2>{p.title}</h2>
            <p>{p.desc}</p>
            <a href="#" class="project-link">View Project ↗</a>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32px 5%;
  }
  .logo { font-weight: 800; font-size: 1.4rem; letter-spacing: -1px; }
  .logo .dot { color: var(--secondary); }
  .nav-links { display: flex; list-style: none; gap: 40px; }
  .nav-links a {
    text-decoration: none;
    color: var(--secondary);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .nav-links a.active, .nav-links a:hover { color: var(--primary); }

  .portfolio-page { padding: 60px 5% 120px; }

  .page-header { margin-bottom: 80px; }
  .page-header h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 20px;
  }
  .muted { color: var(--secondary); }
  .page-header p { font-size: 1.1rem; color: var(--secondary); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .project-card {
    border-radius: 32px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .project-card:hover { transform: translateY(-8px); }

  .project-visual {
    height: 280px;
    background: rgba(0,0,0,0.05);
  }

  .project-info { padding: 40px; }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .project-year {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--secondary);
  }

  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    background: rgba(0,0,0,0.07);
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .project-info h2 {
    font-size: 1.8rem;
    letter-spacing: -1px;
    margin-bottom: 12px;
  }

  .project-info p {
    color: var(--secondary);
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .project-link {
    text-decoration: none;
    font-weight: 700;
    color: var(--primary);
    border-bottom: 2px solid var(--primary);
    padding-bottom: 2px;
  }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
</style>
