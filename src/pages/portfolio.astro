---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const projects = [
  {
    title: "AWS Static Website CI/CD",
    tags: ["S3", "CloudFront", "GitHub Actions", "Astro"],
    desc: "Portfolio website deployed on AWS with a full CI/CD pipeline using OIDC authentication — no secrets stored.",
    year: "2024",
    color: "#F0F0F0"
  },
  {
    title: "3-Tier Architecture on AWS",
    tags: ["ECS Fargate", "Docker", "RDS", "ALB"],
    desc: "Complete 3-tier application architecture on AWS Cloud with auto-scaling and load balancing.",
    year: "2024",
    color: "#EAE8FF"
  },
  {
    title: "Serverless REST API",
    tags: ["Lambda", "API Gateway", "DynamoDB"],
    desc: "Serverless RESTful API capable of handling millions of requests per day with zero server management.",
    year: "2024",
    color: "#E8F5E9"
  },
  {
    title: "DevOps Monitoring Dashboard",
    tags: ["Kubernetes", "Prometheus", "Grafana"],
    desc: "Comprehensive monitoring and observability stack for microservices running on Kubernetes.",
    year: "2024",
    color: "#FFF3E0"
  },
];
---

<Layout title="Portfolio | Truong Tu Dev">
  <Navbar active="portfolio" />

  <main class="page">
    <div class="page-header">
      <div>
        <h1>My <span class="muted">Work</span></h1>
        <p>A collection of my Cloud & DevOps projects</p>
      </div>
      <div class="header-count">
        <span>{projects.length}</span>
        <small>Projects</small>
      </div>
    </div>

    <div class="projects-grid">
      {projects.map((p) => (
        <div class="project-card" style={`background: ${p.color}`}>
          <div class="project-visual"></div>
          <div class="project-info">
            <div class="project-meta">
              <span class="year">{p.year}</span>
              <div class="tags">
                {p.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <h2>{p.title}</h2>
            <p>{p.desc}</p>
            <a href="#" class="project-link">View Project ↗</a>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .page { padding: 40px 5% 120px; }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 80px;
  }

  .page-header h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 16px;
  }
  .muted { color: var(--secondary); }
  .page-header p { font-size: 1rem; color: var(--secondary); }

  .header-count {
    text-align: right;
    padding-top: 8px;
  }
  .header-count span {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -2px;
  }
  .header-count small {
    font-size: 0.75rem;
    color: var(--secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .project-card {
    border-radius: 28px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: pointer;
  }
  .project-card:hover { transform: translateY(-6px); }

  .project-visual {
    height: 260px;
    background: rgba(0,0,0,0.05);
    position: relative;
  }

  .project-info { padding: 36px; }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
  }

  .year {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--secondary);
    letter-spacing: 1px;
  }

  .tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    background: rgba(0,0,0,0.07);
    padding: 3px 10px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .project-info h2 {
    font-size: 1.6rem;
    letter-spacing: -0.8px;
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .project-info p {
    color: var(--secondary);
    line-height: 1.6;
    margin-bottom: 28px;
    font-size: 0.9rem;
  }

  .project-link {
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--primary);
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
  }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
    .page-header { flex-direction: column; gap: 20px; }
  }
</style>
