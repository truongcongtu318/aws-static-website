---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const projects = [
  {
    title: "AWS Static Website CI/CD",
    role: "DevOps Engineer",
    tags: ["S3", "CloudFront", "GitHub Actions", "OIDC", "Astro"],
    desc: "Personal portfolio website deployed on AWS with a fully automated CI/CD pipeline. Uses OIDC authentication — zero long-lived credentials stored on GitHub. Custom domain with SSL via Route 53.",
    highlights: ["Automated deployment on every push to main", "CloudFront Functions for clean URL routing", "Origin Access Control for S3 security"],
    year: "2024",
    color: "#F0F0F0"
  },
  {
    title: "3-Tier Architecture on AWS",
    role: "Cloud Engineer",
    tags: ["ECS Fargate", "Docker", "RDS", "ALB", "VPC"],
    desc: "Production-grade 3-tier application on AWS. Frontend on S3/CloudFront, backend containerized on ECS Fargate behind an ALB, database on RDS with Multi-AZ deployment.",
    highlights: ["Auto Scaling with target tracking", "Private subnet for DB layer", "Blue/Green deployment strategy"],
    year: "2024",
    color: "#EAE8FF"
  },
  {
    title: "Serverless REST API",
    role: "Cloud Engineer",
    tags: ["Lambda", "API Gateway", "DynamoDB", "Python"],
    desc: "Serverless RESTful API handling CRUD operations with zero server management. Built with AWS Lambda and API Gateway, backed by DynamoDB for high-performance NoSQL storage.",
    highlights: ["Pay-per-request pricing model", "Sub-100ms cold start optimization", "API key authentication"],
    year: "2024",
    color: "#E8F5E9"
  },
  {
    title: "Mobile App — Flutter",
    role: "Software Engineer",
    tags: ["Flutter", "Dart", "Firebase", "REST API"],
    desc: "Cross-platform mobile application built during internship at Thien An Studio. Implemented complex UI components, state management with BLoC, and integrated backend APIs.",
    highlights: ["BLoC state management pattern", "Pixel-perfect UI from Figma designs", "Push notifications with FCM"],
    year: "2023",
    color: "#FFF3E0"
  },
];
---

<Layout title="Portfolio | Truong Tu">
  <Navbar active="portfolio" />

  <main class="page">
    <div class="page-header">
      <div>
        <h1>My <span class="muted">Projects</span></h1>
        <p>Real-world projects I've built and deployed — not just code on GitHub</p>
      </div>
    </div>

    <div class="projects-list">
      {projects.map((p, i) => (
        <article class="project-card" style={`background: ${p.color}`}>
          <div class="project-top">
            <div class="project-meta">
              <span class="year">{p.year}</span>
              <span class="role">{p.role}</span>
            </div>
            <div class="tags">
              {p.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <h2>{p.title}</h2>
          <p class="project-desc">{p.desc}</p>
          <ul class="project-highlights">
            {p.highlights.map(h => <li>{h}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style>
  .page { padding: 40px 5% 120px; }

  .page-header {
    margin-bottom: 60px;
  }

  .page-header h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 16px;
  }
  .muted { color: #888; }
  .page-header p { font-size: 1rem; color: #888; }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .project-card {
    border-radius: 28px;
    padding: 48px;
    transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .project-card:hover { transform: translateY(-4px); }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .project-meta { display: flex; gap: 12px; align-items: center; }

  .year {
    font-size: 0.75rem;
    font-weight: 700;
    color: #888;
    letter-spacing: 1px;
  }

  .role {
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(0,0,0,0.08);
    padding: 4px 12px;
    border-radius: 50px;
  }

  .tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    background: rgba(0,0,0,0.07);
    padding: 4px 10px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .project-card h2 {
    font-size: 1.8rem;
    letter-spacing: -1px;
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .project-desc {
    color: #555;
    line-height: 1.65;
    margin-bottom: 20px;
    font-size: 0.92rem;
    max-width: 700px;
  }

  .project-highlights {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .project-highlights li {
    font-size: 0.8rem;
    font-weight: 600;
    color: #333;
    background: rgba(255,255,255,0.6);
    padding: 6px 14px;
    border-radius: 50px;
  }
  .project-highlights li::before {
    content: "✓ ";
    color: #2E7D32;
  }

  @media (max-width: 768px) {
    .project-card { padding: 28px; }
  }
</style>
