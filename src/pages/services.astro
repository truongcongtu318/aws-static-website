---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  { icon: "☁️", title: "AWS Cloud Architecture", desc: "Design and deploy professional Cloud infrastructure: S3, CloudFront, ECS, RDS, Lambda, VPC with security best practices." },
  { icon: "🤖", title: "DevOps & CI/CD", desc: "Build automated deployment pipelines with GitHub Actions, Jenkins, and GitLab CI following enterprise standards." },
  { icon: "🐳", title: "Containerization", desc: "Containerize applications with Docker, manage Kubernetes clusters, and deploy on EKS/ECS at scale." },
  { icon: "🔒", title: "Cloud Security", desc: "Security auditing, IAM configuration, WAF, Security Groups, and AWS Well-Architected compliance." },
  { icon: "📊", title: "Monitoring & Observability", desc: "Set up comprehensive monitoring with CloudWatch, Prometheus, Grafana, and automated alerting systems." },
  { icon: "⚡", title: "Performance Optimization", desc: "Optimize Cloud costs and performance: Auto Scaling, CDN tuning, database query optimization." }
];
---

<Layout title="Services | Truong Tu Dev">
  <Navbar active="services" />

  <main class="page">
    <div class="page-header">
      <div class="header-left">
        <h1>What I <span class="muted">Do</span></h1>
        <p>Professional Cloud & DevOps engineering services</p>
      </div>
      <div class="cta-box">
        <h3>Start your project</h3>
        <p>Let's discuss your idea and I'll help you bring it to life on the Cloud.</p>
        <a href="mailto:tct31082004@gmail.com" class="cta-link">Get in touch ↗</a>
      </div>
    </div>

    <div class="services-grid">
      {services.map(s => <ServiceCard icon={s.icon} title={s.title} desc={s.desc} />)}
    </div>
  </main>
</Layout>

<style>
  .page { padding: 40px 5% 120px; }

  .page-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    margin-bottom: 80px;
  }

  .page-header h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 16px;
  }
  .muted { color: var(--secondary); }
  .header-left p { font-size: 1rem; color: var(--secondary); }

  .cta-box {
    background: var(--primary);
    color: white;
    padding: 48px;
    border-radius: 28px;
  }
  .cta-box h3 {
    font-size: 1.4rem;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }
  .cta-box p {
    opacity: 0.65;
    line-height: 1.6;
    font-size: 0.9rem;
    margin-bottom: 28px;
  }
  .cta-link {
    text-decoration: none;
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 1.5px solid white;
    padding-bottom: 2px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 900px) {
    .page-header { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
