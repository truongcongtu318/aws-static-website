---
interface Props {
  active?: string;
}
const { active = "" } = Astro.props;
---

<nav class="navbar">
  <a href="/" class="logo">
    truongtu<span class="dot">.</span>
  </a>
  <ul class="nav-links" id="navLinks">
    <li><a href="/" class={active === "about" ? "active" : ""}>About Me</a></li>
    <li><a href="/portfolio" class={active === "portfolio" ? "active" : ""}>Portfolio</a></li>
    <li><a href="/services" class={active === "services" ? "active" : ""}>Skills</a></li>
    <li><a href="/blog" class={active === "blog" ? "active" : ""}>Blog</a></li>
  </ul>
  
  <div class="nav-right">
    <a href="mailto:tct31082004@gmail.com" class="book-call">
      Book A Call ↗
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navLinks = document.getElementById('navLinks');

  menuToggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('mobile-open');
    menuToggle?.classList.toggle('active');
    document.body.classList.toggle('menu-open');
  });
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32px 5%;
    position: relative;
    z-index: 10;
  }

  .logo {
    font-size: 1.8rem; /* Tăng từ 1.4 lên 1.8 */
    font-weight: 800;
    text-decoration: none;
    color: var(--primary);
    letter-spacing: -1.5px;
    display: flex;
    align-items: baseline; /* Căn lề theo chân chữ sẽ chuẩn hơn */
    line-height: 1;
  }
  .dot {
    color: #4A90E2; 
    margin-left: 2px;
    font-size: 2.2rem; /* Làm dấu chấm to và nổi bật hơn */
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 40px;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--secondary);
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a.active,
  .nav-links a:hover {
    color: var(--primary);
  }

  /* Book A Call - dạng gạch dưới như Dribbble */
  .book-call {
    text-decoration: none;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
    transition: opacity 0.2s;
    letter-spacing: 0.02em;
  }

  .book-call:hover {
    opacity: 0.6;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* Hamburger Menu Toggle */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 101;
  }
  .menu-toggle span {
    width: 100%;
    height: 2px;
    background: var(--primary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .menu-toggle.active span:first-child { transform: translateY(6px) rotate(45deg); }
  .menu-toggle.active span:last-child { transform: translateY(-6px) rotate(-45deg); }

  @media (max-width: 768px) {
    .menu-toggle { display: flex; }
    .book-call { display: none; } /* Ẩn bớt để tránh chật chội */
    
    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 100%;
      height: 100vh;
      background: white;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 40px;
      transition: right 0.4s cubic-bezier(0.77,0.2,0.05,1.0);
      z-index: 100;
      padding: 0;
    }
    
    .nav-links.mobile-open {
      right: 0;
    }

    .nav-links a {
      font-size: 2rem;
      font-weight: 800;
      color: var(--primary);
    }
  }
</style>
