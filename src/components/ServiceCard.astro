---
interface Props {
	title: string;
	desc: string;
	icon: string;
}

const { title, desc, icon } = Astro.props;
---

<div class="service-card">
	<div class="s-icon">{icon}</div>
	<h3>{title}</h3>
	<p>{desc}</p>
</div>

<style>
	.service-card {
		background: var(--white);
		padding: 50px 40px;
		border-radius: 32px;
		transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		border: 1px solid rgba(0,0,0,0.03);
	}

	.service-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 40px 80px rgba(0,0,0,0.06);
		border-color: rgba(0,0,0,0.08);
	}

	.s-icon {
		font-size: 2.5rem;
		margin-bottom: 25px;
	}

	h3 {
		font-size: 1.5rem;
		margin-bottom: 15px;
		letter-spacing: -0.5px;
	}

	p {
		color: var(--secondary);
		line-height: 1.6;
		font-size: 0.95rem;
	}
</style>
